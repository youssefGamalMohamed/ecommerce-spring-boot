# schema.graphqls

type Cart {
    id: ID
    cartItems: [CartItem]
}

type CartItem {
    id: ID
    productId: Int
    quantity: Int
}

input CartInput {
    cartItems: [CartItemInput]
}

input CartItemInput {
    quantity: Int
    productId: Int
}


type Query {
    findById(id: ID!): Cart
}

type Mutation {
    createCart(cart: CartInput): Cart
}
