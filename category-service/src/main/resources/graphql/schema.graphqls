type Category {
    id: ID!
    name: String!
}

input CategoryInput {
    id: ID
    name: String!
}

type Query {
    findAllCategories: [Category!]!
    findCategoryById(id: ID!): Category
}

type Mutation {
    createCategory(category: CategoryInput!): Category!
    updateCategory(id: ID!, category: CategoryInput!): Category!
    deleteCategory(id: ID!): Boolean!
}
